# Slack (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Comma-separated Slack user IDs allowed to invoke Aspen.
# In dev mode this must be ONLY your own user ID.
# Find yours: Slack → click your name → View full profile → … → Copy member ID
ASPEN_ALLOWED_SLACK_USER_IDS=U0XXXXXXXXX

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Internal secret shared between aspen-bot.py and tool_server.py
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_INTERNAL_SECRET=<32-byte hex string>

# Paths
# CALCULATIONS_ROOT: used by aspen-bot.py for file browsing tools
CALCULATIONS_ROOT=/home/<user>/calculations
# PROJECTS_ROOT: mounted read-only into the bwrap sandbox for analysis
PROJECTS_ROOT=/home/<user>/calculations
# WORKSPACE_ROOT: writable workspace for figures, logs, cache, db
WORKSPACE_ROOT=/home/<user>/aspen_workspace
# SQLITE_DB_ROOT: prefer node-local disk; fall back to WORKSPACE_ROOT/db on Lustre
SQLITE_DB_ROOT=/tmp/aspen_db
# Set to "true" only if SQLITE_DB_ROOT is on local disk (not Lustre/NFS)
SQLITE_USE_WAL=false

# Tool server URL (bot → tool server communication)
TOOL_SERVER_URL=http://127.0.0.1:27195

# ---- Claude Agent SDK backend (these are the defaults) ----
# Requires the claude-agent-sdk package + the Claude Code CLI binary.
# Path to the Claude Code CLI binary. Leave empty to auto-discover `claude` on
# PATH; set it when PATH is minimal (e.g. under systemd). Use the
# version-independent symlink (~/.local/bin/claude), NOT a versioned file.
# Find yours with: which claude
# Example: CLAUDE_CLI_PATH=/home/<user>/.local/bin/claude
CLAUDE_CLI_PATH=
# Auth. true (default) = use the Claude Code login / subscription (you must have
# run `claude` and logged in). false = use ANTHROPIC_API_KEY (API billing).
ASPEN_SDK_USE_SUBSCRIPTION=true
# Per-turn tool-call (agentic round) cap, passed to the SDK as max_turns.
AGENT_MAX_ROUNDS=10
# Upper bound on concurrently parked conversation sessions.
MAX_OPEN_SESSIONS=20
# Built-in Bash tool allowlist for HPC job investigation. Comma-separated Claude
# Code permission rules; "Bash(cmd:*)" is a prefix match. Matching commands run
# without prompting; everything else is denied. Leave unset for the read-only
# default (Slurm: squeue/sacct/sinfo/sstat/sprio/'scontrol show'; text: grep/ls/
# cat/head/tail/wc/sort/uniq). find/awk/sed are excluded on purpose — their flags
# (-exec, system(), w/e) can write files or run commands the prefix can't see.
# Example: ASPEN_BASH_ALLOWLIST=Bash(squeue:*),Bash(sacct:*),Bash(grep:*)
ASPEN_BASH_ALLOWLIST=

# ---- Bash OS sandbox (give the agent a WRITE surface you control) ----
# Off by default. When true, the agent's Bash commands run inside Claude Code's
# OS sandbox (Linux: bubblewrap + socat — `apt-get install bubblewrap socat`;
# macOS: built-in Seatbelt). The agent can then read broadly and WRITE only
# within the paths you grant below — a boundary enforced by the OS, separate
# from what the bot's Unix user can touch. See https://code.claude.com/docs/en/sandboxing
# The read-only Slurm commands below run OUTSIDE the jail (they need cluster
# network/munge) but stay gated by ASPEN_BASH_ALLOWLIST.
#
# Verified enforcing 2026-06-24 (CLI 2.1.190 + bubblewrap 0.4.0): writes outside
# the allow-list are blocked. Two requirements: (1) `socat` + `bubblewrap` must be
# installed (start.sh bootstraps socat without sudo); (2) the bot must run as a
# normal top-level process — Claude Code disables the sandbox if it's launched
# nested inside another Claude Code session. Verify anytime: ./verify_sandbox.sh
# from a plain shell. Default off; flip to true after setting the write paths below.
ASPEN_SANDBOX_ENABLED=false
# Fail closed: refuse to start if the sandbox can't initialize (missing bwrap,
# unsupported platform) instead of silently running unsandboxed. Keep true.
ASPEN_SANDBOX_FAIL_IF_UNAVAILABLE=true
# Auto-approve commands that run inside the jail (no per-command prompt).
ASPEN_SANDBOX_AUTO_ALLOW=true
# Allow escaping the jail via dangerouslyDisableSandbox. Keep false (strict).
ASPEN_SANDBOX_ALLOW_UNSANDBOXED=false
# Session working dir when sandboxed (writable by default). Defaults to
# WORKSPACE_ROOT. Point it at a scratch dir so the agent stays out of repo/home.
ASPEN_SANDBOX_WORKDIR=
# Comma-separated paths the agent may WRITE to (the surface you grant). Prefixes:
# "/abs" absolute, "~/x" home-relative, "x" relative to the workdir.
# Example: ASPEN_SANDBOX_WRITE_PATHS=/scratch/aspen,~/aspen_out
ASPEN_SANDBOX_WRITE_PATHS=
# Optional read controls inside the jail (e.g. hide credentials).
# Example: ASPEN_SANDBOX_DENY_READ_PATHS=~/.ssh,~/.aws
ASPEN_SANDBOX_DENY_READ_PATHS=
ASPEN_SANDBOX_ALLOW_READ_PATHS=
# Network domains reachable from the jail. Empty = no network (safest).
# Example: ASPEN_SANDBOX_ALLOWED_DOMAINS=pypi.org,files.pythonhosted.org
ASPEN_SANDBOX_ALLOWED_DOMAINS=
# Unix sockets reachable from the jail. Careful — docker.sock is an escape.
ASPEN_SANDBOX_UNIX_SOCKETS=
# Commands that run OUTSIDE the jail (need host network/munge). Default = the
# read-only Slurm clients. They remain gated by ASPEN_BASH_ALLOWLIST.
ASPEN_SANDBOX_EXCLUDED_COMMANDS=squeue,sacct,sinfo,sstat,sprio,scontrol

# ---- optional tuning (these are the defaults) ----
ANTHROPIC_MODEL=claude-opus-4-8
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=600
CONTEXT_EXPIRY_SECONDS=14400
MAX_CONCURRENT_EXECUTIONS=5
MAX_FILE_READ_BYTES=50000
MAX_STDOUT_CHARS=10000
MAX_STDERR_CHARS=2000
MAX_FIGURE_BYTES=5242880
FIGURE_ARCHIVE_MAX_BYTES=2147483648
FIGURE_ARCHIVE_TRIM_BYTES=1610612736
EXECUTION_TIMEOUT_SECONDS=120

# ---- Analysis sandbox (bwrap) ----
# run_python_analysis runs LLM-generated code under bubblewrap (no network,
# read-only project mount, only figures/cache writable). Requires `bubblewrap`.
# ANALYSIS_PYTHON: interpreter (a venv) with the analysis libraries. start.sh
# builds this venv from analysis-requirements.txt and exports this var; set it
# only to point at an interpreter you manage yourself.
# Default: $WORKSPACE_ROOT/analysis-venv/bin/python
ANALYSIS_PYTHON=
# ANALYSIS_VENV: where start.sh builds the analysis venv (default below).
# ANALYSIS_VENV=/home/<user>/aspen_workspace/analysis-venv
# BWRAP_BIN: bubblewrap binary (default: bwrap on PATH).
# BWRAP_BIN=bwrap
# Extra host paths bind-mounted read-only so the interpreter's shared libs resolve.
# ANALYSIS_RO_PATHS=/usr,/lib,/lib64,/bin,/sbin
# Per-task resource caps (bwrap has no cgroup limits; enforced via prlimit). 0 = off.
# RLIMIT_AS caps virtual address space; set generously (BLAS reserves large arenas) —
# the wall-clock timeout above is the primary backstop.
ANALYSIS_AS_LIMIT_BYTES=2147483648
ANALYSIS_FSIZE_LIMIT_BYTES=536870912
# CPU-seconds cap (SIGXCPU). Empty/unset defaults to EXECUTION_TIMEOUT_SECONDS.
# ANALYSIS_CPU_LIMIT_SECONDS=120
