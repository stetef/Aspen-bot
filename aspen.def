Bootstrap: docker
From: python:3.11-slim

%post
    pip install --no-cache-dir \
        numpy \
        pandas \
        matplotlib \
        scipy \
        py3Dmol
    pip cache purge
    # Remove everything that could provide network access or shell execution
    apt-get remove -y --purge curl wget openssh-client 2>/dev/null || true
    apt-get autoremove -y 2>/dev/null || true

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    # No PATH additions — only the base python binary

%labels
    Author Aspen
    Version 1.0
    Description Minimal Python sandbox for computational chemistry analysis.
    AllowedLibraries numpy,pandas,matplotlib,scipy

%help
    Minimal Python 3.11 sandbox for Aspen analysis tasks.
    Contains: numpy, pandas, matplotlib, scipy.

    Build with:
        apptainer build aspen.sif aspen.def

    To add libraries, update the %post pip install line and rebuild.
    After rebuilding, restart the tool server so it uses the new image.
